@page
@model CadernoVivo.Pages.Artigos.Tarefas.IndexModel
@{
    ViewData["Title"] = "Tarefas – Artigos";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-page="/Artigos/Index">Artigos</a></li>
    <li class="breadcrumb-item active">Tarefas</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-check2-square text-primary me-2"></i>Tarefas de Artigos</h4>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2 flex-wrap align-items-center">
            <select name="artigo" class="form-select form-select-sm" style="width:220px">
                <option value="">Todos os artigos</option>
                @foreach (var art in Model.Artigos)
                {
                    <option value="@art.Id" selected="@(Model.FiltroArtigo == art.Id)">@art.Titulo</option>
                }
            </select>
            <select name="status" class="form-select form-select-sm" style="width:160px">
                <option value="">Todos os status</option>
                @foreach (StatusTarefa s in Enum.GetValues(typeof(StatusTarefa)))
                {
                    <option value="@s" selected="@(Model.FiltroStatus == s.ToString())">@DiasHelper.LabelStatus(s)</option>
                }
            </select>
            <button type="submit" class="btn btn-sm btn-outline-primary">Filtrar</button>
            <a asp-page="Index" class="btn btn-sm btn-outline-secondary">Limpar</a>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Tarefas.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-inbox fs-2 d-block mb-2"></i>Nenhuma tarefa encontrada.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Tarefa</th>
                            <th>Artigo</th>
                            <th>Prazo</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.Tarefas)
                        {
                            var atrasada = t.Status != StatusTarefa.Concluida && t.DataHoraLimite < DateTime.Now;
                            <tr>
                                <td>
                                    <div class="fw-semibold">@t.Titulo</div>
                                    @if (t.Descricao != null)
                                    {
                                        <small class="text-muted">@t.Descricao</small>
                                    }
                                </td>
                                <td>
                                    <a asp-page="/Artigos/Detalhes" asp-route-id="@t.ArtigoId"
                                       class="badge bg-purple bg-opacity-10 text-decoration-none" style="color:#7e22ce">
                                        @t.Artigo.Titulo
                                    </a>
                                </td>
                                <td class="@(atrasada ? "text-danger fw-bold" : "")">
                                    @t.DataHoraLimite.ToString("dd/MM/yyyy HH:mm")
                                    @if (atrasada) { <span class="badge bg-danger ms-1">Atrasada</span> }
                                </td>
                                <td><span class="badge bg-@DiasHelper.ClasseStatus(t.Status)">@DiasHelper.LabelStatus(t.Status)</span></td>
                                <td>
                                    <a asp-page="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
