@page
@model CadernoVivo.Pages.Artigos.CreateModel
@{
    ViewData["Title"] = "Novo Artigo";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-page="Index">Artigos</a></li>
    <li class="breadcrumb-item active">Novo</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Novo Artigo</h4>
    <a asp-page="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Voltar
    </a>
</div>

<div class="card" style="max-width:620px">
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="Artigo.Titulo" class="form-label"></label>
                <input asp-for="Artigo.Titulo" class="form-control" placeholder="Ex: Como usar EF Core com SQLite" />
                <span asp-validation-for="Artigo.Titulo" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Artigo.Descricao" class="form-label"></label>
                <textarea asp-for="Artigo.Descricao" class="form-control" rows="3"
                          placeholder="Resumo ou objetivo do artigo"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="Artigo.Tags" class="form-label"></label>
                <input asp-for="Artigo.Tags" class="form-control" placeholder="Ex: csharp, efcore, sqlite" />
                <small class="text-muted">Separe as tags por vírgula</small>
            </div>
            <div class="mb-3">
                <label asp-for="Artigo.Status" class="form-label"></label>
                <select asp-for="Artigo.Status" class="form-select"
                        asp-items="Html.GetEnumSelectList<StatusArtigo>()"></select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Criar artigo
                </button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
