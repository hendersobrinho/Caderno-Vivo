@page "{id:int}"
@model CadernoVivo.Pages.Faculdade.Tarefas.EditModel
@{
    ViewData["Title"] = "Editar Tarefa";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-page="/Faculdade/Tarefas/Index">Tarefas</a></li>
    <li class="breadcrumb-item active">Editar</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Editar Tarefa</h4>
    <a asp-page="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Voltar
    </a>
</div>

<div class="card" style="max-width:600px">
    <div class="card-body">
        <div class="alert alert-info small mb-3">
            <i class="bi bi-info-circle me-1"></i>
            Se marcar como <strong>Parcial</strong> ou <strong>Não Encaixou</strong>, uma pendência será criada automaticamente.
        </div>
        <form method="post">
            <input type="hidden" asp-for="Tarefa.Id" />
            <input type="hidden" asp-for="Tarefa.DataCriacao" />
            <input type="hidden" asp-for="Tarefa.DataConclusao" />

            <div class="mb-3">
                <label asp-for="Tarefa.Titulo" class="form-label"></label>
                <input asp-for="Tarefa.Titulo" class="form-control" />
                <span asp-validation-for="Tarefa.Titulo" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Tarefa.MateriaId" class="form-label">Matéria</label>
                <select asp-for="Tarefa.MateriaId" class="form-select"
                        asp-items="@(new SelectList(Model.Materias, "Id", "Nome"))"></select>
            </div>
            <div class="mb-3">
                <label asp-for="Tarefa.Descricao" class="form-label"></label>
                <textarea asp-for="Tarefa.Descricao" class="form-control" rows="3"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="Tarefa.DataHoraLimite" class="form-label"></label>
                <input asp-for="Tarefa.DataHoraLimite" class="form-control" type="datetime-local" />
            </div>
            <div class="mb-3">
                <label asp-for="Tarefa.Status" class="form-label"></label>
                <select asp-for="Tarefa.Status" class="form-select"
                        asp-items="Html.GetEnumSelectList<StatusTarefa>()"></select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Salvar
                </button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
