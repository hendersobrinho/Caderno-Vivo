@page
@model CadernoVivo.Pages.Faculdade.Materias.CreateModel
@{
    ViewData["Title"] = "Nova Matéria";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-page="/Faculdade/Index">Faculdade</a></li>
    <li class="breadcrumb-item active">Nova Matéria</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Nova Matéria</h4>
    <a asp-page="/Faculdade/Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Voltar
    </a>
</div>

<div class="card" style="max-width:600px">
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Materia.Nome" class="form-label"></label>
                <input asp-for="Materia.Nome" class="form-control" placeholder="Ex: Algoritmos e Estruturas de Dados" />
                <span asp-validation-for="Materia.Nome" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Materia.Professor" class="form-label"></label>
                <input asp-for="Materia.Professor" class="form-control" placeholder="Ex: Prof. João Silva" />
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Materia.Semestre" class="form-label"></label>
                    <input asp-for="Materia.Semestre" class="form-control" placeholder="Ex: 1/2025" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Materia.CargaHoraria" class="form-label"></label>
                    <input asp-for="Materia.CargaHoraria" class="form-control" type="number" min="1" />
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Materia.Descricao" class="form-label"></label>
                <textarea asp-for="Materia.Descricao" class="form-control" rows="3"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Salvar
                </button>
                <a asp-page="/Faculdade/Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
