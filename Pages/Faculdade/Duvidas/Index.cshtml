@page
@model CadernoVivo.Pages.Faculdade.Duvidas.IndexModel
@{
    ViewData["Title"] = "Dúvidas – Faculdade";
    var abertas = Model.Duvidas.Where(d => !d.Resolvida).ToList();
    var resolvidas = Model.Duvidas.Where(d => d.Resolvida).ToList();
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-page="/Faculdade/Index">Faculdade</a></li>
    <li class="breadcrumb-item active">Dúvidas</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-question-circle text-warning me-2"></i>Dúvidas da Faculdade</h4>
    <span class="badge bg-warning text-dark fs-6">@abertas.Count em aberto</span>
</div>

@if (abertas.Any())
{
    <div class="card mb-4">
        <div class="card-header text-warning"><i class="bi bi-circle-fill me-2"></i>Em aberto</div>
        <div class="card-body p-0">
            @foreach (var d in abertas)
            {
                <div class="border-bottom p-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fw-semibold">@d.Descricao</div>
                            <small class="text-muted"><span class="badge bg-primary bg-opacity-10 text-primary me-1">@d.Materia.Nome</span> @d.DataRegistro.ToString("dd/MM/yyyy")</small>
                        </div>
                    </div>
                    <form method="post" asp-page-handler="Resolver" asp-route-id="@d.Id" class="mt-2 d-flex gap-2">
                        <input name="resolucao" class="form-control form-control-sm" placeholder="Descreva a resolução..." />
                        <button class="btn btn-sm btn-success text-nowrap">
                            <i class="bi bi-check-lg me-1"></i>Resolver
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
}

@if (resolvidas.Any())
{
    <div class="card">
        <div class="card-header text-success"><i class="bi bi-check-circle-fill me-2"></i>Resolvidas (@resolvidas.Count)</div>
        <div class="card-body p-0">
            @foreach (var d in resolvidas)
            {
                <div class="border-bottom p-3">
                    <div class="text-muted text-decoration-line-through small">@d.Descricao</div>
                    @if (d.Resolucao != null)
                    {
                        <div class="small text-success mt-1"><i class="bi bi-check me-1"></i>@d.Resolucao</div>
                    }
                    <small class="text-muted"><span class="badge bg-light text-secondary me-1">@d.Materia.Nome</span></small>
                </div>
            }
        </div>
    </div>
}

@if (!Model.Duvidas.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-patch-check display-4 d-block mb-3"></i>
        <p>Nenhuma dúvida registrada. Adicione dúvidas dentro de cada matéria.</p>
    </div>
}
