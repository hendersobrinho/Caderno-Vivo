@page
@model CadernoVivo.Pages.Faculdade.IndexModel
@{
    ViewData["Title"] = "Faculdade – Base de Matérias";
}

@section Breadcrumb {
    <li class="breadcrumb-item active">Faculdade</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-mortarboard-fill text-primary me-2"></i>Base de Matérias</h4>
        <small class="text-muted">Opcional: o importador cria matérias automaticamente quando o plano trouxer o nome.</small>
    </div>
    <a asp-page="/Faculdade/Materias/Create" class="btn btn-outline-secondary">
        <i class="bi bi-plus-lg me-1"></i>Adicionar manualmente
    </a>
</div>

@if (!Model.Materias.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-mortarboard display-4 d-block mb-3"></i>
        <p class="mb-1">Nenhuma matéria na base ainda.</p>
        <p class="small">Ao importar um plano da faculdade, as matérias do JSON entram aqui automaticamente.</p>
        <a asp-page="/PlanoImportar/Index" class="btn btn-primary">Importar plano</a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var m in Model.Materias)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">@m.Nome</h5>
                            @if (m.Semestre != null)
                            {
                                <span class="badge bg-light text-secondary">@m.Semestre</span>
                            }
                        </div>
                        @if (m.Professor != null)
                        {
                            <p class="text-muted small mb-2"><i class="bi bi-person me-1"></i>@m.Professor</p>
                        }
                        @if (m.Descricao != null)
                        {
                            <p class="small text-muted mb-3">@m.Descricao</p>
                        }
                        <div class="d-flex gap-2 flex-wrap mb-3">
                            <span class="badge bg-primary bg-opacity-10 text-primary">
                                <i class="bi bi-calendar3 me-1"></i>@m.AulasSemanais.Count aula(s)/semana
                            </span>
                        </div>
                        <div class="d-flex gap-2">
                            <a asp-page="/Faculdade/Materias/Detalhes" asp-route-id="@m.Id" class="btn btn-sm btn-primary flex-grow-1">
                                <i class="bi bi-folder2-open me-1"></i>Abrir
                            </a>
                            <a asp-page="/Faculdade/Materias/Edit" asp-route-id="@m.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-page="/Faculdade/Materias/Delete" asp-route-id="@m.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
