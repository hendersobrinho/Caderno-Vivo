@page
@model CadernoVivo.Pages.Faculdade.IndexModel
@{
    ViewData["Title"] = "Faculdade – Matérias";
}

@section Breadcrumb {
    <li class="breadcrumb-item active">Faculdade</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-mortarboard-fill text-primary me-2"></i>Matérias</h4>
    <a asp-page="/Faculdade/Materias/Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Nova matéria
    </a>
</div>

@if (!Model.Materias.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-mortarboard display-4 d-block mb-3"></i>
        <p>Nenhuma matéria cadastrada ainda.</p>
        <a asp-page="/Faculdade/Materias/Create" class="btn btn-primary">Cadastrar primeira matéria</a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var m in Model.Materias)
        {
            var pendentes = m.Tarefas.Count(t => t.Status == StatusTarefa.Pendente || t.Status == StatusTarefa.EmAndamento);
            var duvidasAbertas = m.Duvidas.Count(d => !d.Resolvida);
            <div class="col-md-6 col-xl-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">@m.Nome</h5>
                            @if (m.Semestre != null)
                            {
                                <span class="badge bg-light text-secondary">@m.Semestre</span>
                            }
                        </div>
                        @if (m.Professor != null)
                        {
                            <p class="text-muted small mb-2"><i class="bi bi-person me-1"></i>@m.Professor</p>
                        }
                        @if (m.Descricao != null)
                        {
                            <p class="small text-muted mb-3">@m.Descricao</p>
                        }
                        <div class="d-flex gap-2 flex-wrap mb-3">
                            <span class="badge bg-primary bg-opacity-10 text-primary">
                                <i class="bi bi-calendar3 me-1"></i>@m.AulasSemanais.Count aula(s)/semana
                            </span>
                            @if (pendentes > 0)
                            {
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-hourglass me-1"></i>@pendentes tarefa(s)
                                </span>
                            }
                            @if (duvidasAbertas > 0)
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger">
                                    <i class="bi bi-question-circle me-1"></i>@duvidasAbertas dúvida(s)
                                </span>
                            }
                        </div>
                        <div class="d-flex gap-2">
                            <a asp-page="/Faculdade/Materias/Detalhes" asp-route-id="@m.Id" class="btn btn-sm btn-primary flex-grow-1">
                                <i class="bi bi-folder2-open me-1"></i>Abrir
                            </a>
                            <a asp-page="/Faculdade/Materias/Edit" asp-route-id="@m.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-page="/Faculdade/Materias/Delete" asp-route-id="@m.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
