@page
@model CadernoVivo.Pages.Projetos.Importar.IndexModel
@{
    ViewData["Title"] = "Importar Projeto";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-page="/Projetos/Index">Projetos</a></li>
    <li class="breadcrumb-item active">Importar</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-file-earmark-arrow-down me-2 text-primary"></i>Importar Projeto com Cronograma</h4>
        <p class="text-muted small mb-0">Cole um JSON no formato abaixo para criar o projeto e agendar todas as sessões automaticamente.</p>
    </div>
</div>

@if (Model.ProjetoImportadoId.HasValue)
{
    <div class="alert alert-success d-flex align-items-center gap-3">
        <i class="bi bi-check-circle-fill fs-4"></i>
        <div>
            <strong>@Model.ProjetoImportadoTitulo</strong> importado com sucesso.
            @if (Model.SessoesAgendadas > 0)
            {
                <span>@Model.SessoesAgendadas sessão(ões) agendadas na fila de hoje.</span>
            }
            <div class="mt-2">
                <a asp-page="/Projetos/Detalhes" asp-route-id="@Model.ProjetoImportadoId" class="btn btn-sm btn-success me-2">
                    <i class="bi bi-kanban me-1"></i>Abrir projeto
                </a>
                <a asp-page="/Projetos/Importar/Index" class="btn btn-sm btn-outline-secondary">
                    Importar outro
                </a>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.Erro))
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@Model.Erro</div>
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header"><i class="bi bi-braces me-2"></i>JSON do Projeto</div>
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Carregar arquivo .json</label>
                        <input type="file" id="arquivoJson" accept=".json,application/json"
                               class="form-control form-control-sm" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Ou cole o JSON aqui</label>
                        <textarea asp-for="JsonTexto" id="jsonTexto" class="form-control font-monospace" rows="18"
                                  placeholder='{"tipo": "projeto", "titulo": "...", ...}'
                                  style="font-size:0.82rem"></textarea>
                    </div>
                    <div class="text-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-file-earmark-arrow-down me-1"></i>Importar Projeto
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header"><i class="bi bi-info-circle me-2"></i>Formato esperado</div>
            <div class="card-body">
                <pre class="small text-muted mb-0" style="white-space:pre-wrap;font-size:0.78rem">{
  "tipo": "projeto",
  "titulo": "Estudo de Rust",
  "descricao": "Dominar a linguagem",
  "prioridade": "Alta",
  "categoria": "Pessoal",
  "materia": "Computação",

  "recorrencia": {
    "dias": ["domingo"],
    "hora_inicio": "14:00",
    "hora_fim": "17:00"
  },

  "sessoes": [
    {
      "titulo": "Sessão 1 – Ownership",
      "descricao": "Cap. 4 do livro"
    },
    {
      "titulo": "Sessão 2 – Structs",
      "descricao": "Cap. 5 e 6"
    }
  ],

  "checklist": [
    "Configurar ambiente",
    "Instalar rustup",
    "Fazer exercícios finais"
  ]
}</pre>
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body">
                <h6 class="fw-semibold mb-2"><i class="bi bi-calendar-week me-2 text-primary"></i>Dias aceitos</h6>
                <p class="small text-muted mb-2">O campo <code>dias</code> aceita os seguintes valores (em português ou inglês):</p>
                <div class="d-flex flex-wrap gap-1">
                    @foreach (var d in new[] { "domingo", "segunda", "terça", "quarta", "quinta", "sexta", "sábado" })
                    {
                        <code class="badge bg-secondary-subtle text-secondary-emphasis">@d</code>
                    }
                </div>
                <hr class="my-3" />
                <h6 class="fw-semibold mb-2"><i class="bi bi-arrow-repeat me-2 text-warning"></i>Pausa e retomada</h6>
                <p class="small text-muted mb-0">
                    Ao <strong>pausar</strong> o projeto, os blocos futuros agendados são removidos.
                    Ao <strong>retomar</strong>, o sistema recalcula automaticamente as próximas datas
                    e recria os blocos a partir de onde você parou.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('arquivoJson')?.addEventListener('change', function() {
    var file = this.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function(e) {
        document.getElementById('jsonTexto').value = e.target.result;
    };
    reader.readAsText(file, 'UTF-8');
});
</script>
}
