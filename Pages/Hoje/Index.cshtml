@page
@model CadernoVivo.Pages.Hoje.IndexModel
@using CadernoVivo.Helpers
@using CadernoVivo.Models
@{
    ViewData["Title"] = "Hoje";
    var hoje = DateTime.Today;
    var diaSemana = DiasHelper.NomeDia((int)hoje.DayOfWeek);
    var dataFormatada = $"{diaSemana}, {hoje:dd/MM/yyyy}";
}

@section Breadcrumb {
    <li class="breadcrumb-item active">Hoje</li>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-calendar-check me-2 text-primary"></i>@dataFormatada
    </h4>
    <div class="d-flex gap-2">
        <a asp-page="/PlanoImportar/Index" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-cloud-upload me-1"></i>Importar Plano
        </a>
        <a asp-page="/Exportar/Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-box-arrow-up me-1"></i>Exportar
        </a>
    </div>
</div>

@if (!Model.BloquesHoje.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body">
            <i class="bi bi-calendar-x display-3 text-muted"></i>
            <h5 class="mt-3 text-muted">Nenhum bloco para hoje</h5>
            <p class="text-muted small">Importe um plano do ChatGPT ou adicione um bloco manualmente.</p>
            <div class="d-flex gap-2 justify-content-center mt-3">
                <a asp-page="/PlanoImportar/Index" class="btn btn-primary">
                    <i class="bi bi-cloud-upload me-1"></i>Importar Plano
                </a>
                <button class="btn btn-outline-secondary" type="button"
                        data-bs-toggle="collapse" data-bs-target="#formAdicionarBloco">
                    <i class="bi bi-plus-circle me-1"></i>Adicionar Bloco
                </button>
            </div>
        </div>
    </div>
}
else
{
    <div class="row g-3">

        <!-- Bloco Atual -->
        <div class="col-12">
            @if (Model.BlocoAtual != null)
            {
                var bloco = Model.BlocoAtual;
                var classeStatus = DiasHelper.ClasseStatusBloco(bloco.Status);
                <div class="card border-0 shadow bloco-atual" id="card-bloco-atual">
                    <div class="card-header d-flex justify-content-between align-items-center bg-primary text-white py-2">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-hourglass-split"></i>
                            <span class="fw-semibold">BLOCO ATUAL</span>
                            <span class="badge bg-white text-primary ms-1">@bloco.HoraInicio – @bloco.HoraFim</span>
                        </div>
                        <div id="timer-display" class="fw-bold font-monospace fs-5">--:--</div>
                    </div>

                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-8">
                                <h5 class="fw-bold mb-1">@bloco.Titulo</h5>
                                @if (!string.IsNullOrWhiteSpace(bloco.Descricao))
                                {
                                    <p class="text-muted small mb-2">@bloco.Descricao</p>
                                }
                                <div class="d-flex gap-2 flex-wrap mb-2">
                                    @if (bloco.Materia != null)
                                    {
                                        <span class="badge bg-primary-subtle text-primary-emphasis">
                                            <i class="bi bi-mortarboard me-1"></i>@bloco.Materia.Nome
                                        </span>
                                    }
                                    @if (bloco.Artigo != null)
                                    {
                                        <span class="badge bg-info-subtle text-info-emphasis">
                                            <i class="bi bi-journal-text me-1"></i>@bloco.Artigo.Titulo
                                        </span>
                                    }
                                    <span class="badge bg-@classeStatus">
                                        <i class="bi @DiasHelper.IconeStatusBloco(bloco.Status) me-1"></i>
                                        @DiasHelper.LabelStatusBloco(bloco.Status)
                                    </span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(bloco.OndeParei))
                                {
                                    <div class="text-muted small">
                                        <i class="bi bi-bookmark me-1"></i><strong>Onde parei:</strong> @bloco.OndeParei
                                    </div>
                                }
                            </div>
                            <div class="col-md-4 d-flex flex-column gap-2">
                                @if (bloco.Status == StatusBloco.Agendado)
                                {
                                    <form method="post" asp-page-handler="Iniciar">
                                        <input type="hidden" name="id" value="@bloco.Id" />
                                        <button type="submit" class="btn btn-primary w-100">
                                            <i class="bi bi-play-fill me-1"></i>Iniciar
                                        </button>
                                    </form>
                                }
                                <button class="btn btn-outline-success w-100" onclick="abrirFinalizar(@bloco.Id)">
                                    <i class="bi bi-check2-circle me-1"></i>Finalizar Bloco
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm border-start border-4 border-secondary">
                    <div class="card-body text-muted">
                        <i class="bi bi-clock me-2"></i>Nenhum bloco em andamento no momento.
                    </div>
                </div>
            }
        </div>

        <!-- Próximo Bloco -->
        @if (Model.ProximoBloco != null)
        {
            var prox = Model.ProximoBloco;
            <div class="col-12">
                <div class="card border-0 shadow-sm border-start border-4 border-info">
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <small class="text-muted text-uppercase fw-semibold">
                                    <i class="bi bi-arrow-right-circle me-1 text-info"></i>Próximo
                                </small>
                                <div class="fw-semibold">@prox.Titulo</div>
                                @if (prox.Materia != null)
                                {
                                    <small class="text-muted"><i class="bi bi-mortarboard me-1"></i>@prox.Materia.Nome</small>
                                }
                                @if (prox.Artigo != null)
                                {
                                    <small class="text-muted"><i class="bi bi-journal-text me-1"></i>@prox.Artigo.Titulo</small>
                                }
                            </div>
                            <span class="badge bg-secondary font-monospace">@prox.HoraInicio – @prox.HoraFim</span>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Agenda do Dia -->
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent border-0 pb-0 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0"><i class="bi bi-list-ul me-2"></i>Agenda de Hoje</h6>
                    <button class="btn btn-sm btn-outline-primary" type="button"
                            data-bs-toggle="collapse" data-bs-target="#formAdicionarBloco">
                        <i class="bi bi-plus me-1"></i>Adicionar
                    </button>
                </div>
                <div class="card-body pt-2">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:110px">Horário</th>
                                    <th>Bloco</th>
                                    <th style="width:130px">Status</th>
                                    <th style="width:90px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var b in Model.BloquesHoje)
                                {
                                    var isAtual = Model.BlocoAtual?.Id == b.Id;
                                    var rowClass = isAtual ? "table-primary fw-semibold" : "";
                                    <tr class="@rowClass">
                                        <td class="font-monospace small">@b.HoraInicio–@b.HoraFim</td>
                                        <td>
                                            <div>@b.Titulo</div>
                                            @if (b.Materia != null)
                                            {
                                                <small class="text-muted"><i class="bi bi-mortarboard me-1"></i>@b.Materia.Nome</small>
                                            }
                                            @if (b.Artigo != null)
                                            {
                                                <small class="text-muted"><i class="bi bi-journal-text me-1"></i>@b.Artigo.Titulo</small>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(b.OndeParei))
                                            {
                                                <div class="text-muted small"><i class="bi bi-bookmark me-1"></i>@b.OndeParei</div>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge bg-@DiasHelper.ClasseStatusBloco(b.Status)">
                                                <i class="bi @DiasHelper.IconeStatusBloco(b.Status) me-1"></i>
                                                @DiasHelper.LabelStatusBloco(b.Status)
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            @if (b.Status == StatusBloco.Agendado || b.Status == StatusBloco.EmAndamento)
                                            {
                                                <button class="btn btn-sm btn-outline-success" onclick="abrirFinalizar(@b.Id)" title="Finalizar">
                                                    <i class="bi bi-check2"></i>
                                                </button>
                                            }
                                            <form method="post" asp-page-handler="Excluir" class="d-inline"
                                                  onsubmit="return confirm('Excluir este bloco?')">
                                                <input type="hidden" name="id" value="@b.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Excluir">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
}

<!-- Form Adicionar Bloco (sempre presente) -->
<div class="collapse mt-3" id="formAdicionarBloco">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent border-0">
            <h6 class="fw-bold mb-0"><i class="bi bi-plus-circle me-2"></i>Adicionar Bloco Manual</h6>
        </div>
        <div class="card-body">
            <form method="post" asp-page-handler="AdicionarBloco">
                <div class="row g-2">
                    <div class="col-md-2">
                        <label class="form-label small fw-semibold">Data</label>
                        <input asp-for="NovoBloco.Data" type="date" class="form-control form-control-sm"
                               value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-1">
                        <label class="form-label small fw-semibold">Início</label>
                        <input asp-for="NovoBloco.HoraInicio" type="time" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-1">
                        <label class="form-label small fw-semibold">Fim</label>
                        <input asp-for="NovoBloco.HoraFim" type="time" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Título *</label>
                        <input asp-for="NovoBloco.Titulo" class="form-control form-control-sm" placeholder="Ex: Cálculo – Derivadas" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-semibold">Módulo</label>
                        <select asp-for="NovoBloco.Modulo" class="form-select form-select-sm">
                            <option value="Geral">Geral</option>
                            <option value="Faculdade">Faculdade</option>
                            <option value="Artigo">Artigo</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-semibold">Matéria</label>
                        <select asp-for="NovoBloco.MateriaId" class="form-select form-select-sm">
                            <option value="">— nenhuma —</option>
                            @foreach (var m in Model.Materias)
                            {
                                <option value="@m.Id">@m.Nome</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-semibold">Artigo</label>
                        <select asp-for="NovoBloco.ArtigoId" class="form-select form-select-sm">
                            <option value="">— nenhum —</option>
                            @foreach (var a in Model.Artigos)
                            {
                                <option value="@a.Id">@a.Titulo</option>
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Descrição / Objetivo</label>
                        <input asp-for="NovoBloco.Descricao" class="form-control form-control-sm"
                               placeholder="Opcional — o que será feito neste bloco" />
                    </div>
                    <div class="col-12 text-end">
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="bi bi-plus-circle me-1"></i>Adicionar Bloco
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Finalizar Bloco -->
<div class="modal fade" id="modalFinalizar" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-check2-circle me-2"></i>Finalizar Bloco</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Finalizar" id="formFinalizar">
                <div class="modal-body">
                    <input type="hidden" name="id" id="finalizarId" />

                    <!-- Botões de status -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Como foi este bloco?</label>
                        <input type="hidden" name="status" id="finalizarStatus" value="Concluido" />
                        <div class="d-flex gap-2 flex-wrap">
                            <button type="button" class="btn btn-success btn-status active"
                                    data-status="Concluido" onclick="setStatus('Concluido', this)">
                                <i class="bi bi-check-circle-fill me-1"></i>Concluído
                            </button>
                            <button type="button" class="btn btn-outline-warning btn-status"
                                    data-status="Parcial" onclick="setStatus('Parcial', this)">
                                <i class="bi bi-dash-circle me-1"></i>Parcial
                            </button>
                            <button type="button" class="btn btn-outline-danger btn-status"
                                    data-status="NaoFeito" onclick="setStatus('NaoFeito', this)">
                                <i class="bi bi-x-circle me-1"></i>Não Feito
                            </button>
                            <button type="button" class="btn btn-outline-info btn-status"
                                    data-status="Reagendado" onclick="setStatus('Reagendado', this)">
                                <i class="bi bi-calendar-plus me-1"></i>Reagendar
                            </button>
                            <button type="button" class="btn btn-outline-dark btn-status"
                                    data-status="HoraExtra" onclick="setStatus('HoraExtra', this)">
                                <i class="bi bi-clock-history me-1"></i>Hora Extra
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-bookmark me-1 text-primary"></i>Onde parei
                        </label>
                        <input type="text" name="ondeParei" class="form-control"
                               placeholder="Ex: Página 47, seção 3.2 — Derivadas parciais" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-arrow-right-circle me-1 text-success"></i>Próximo passo
                        </label>
                        <input type="text" name="proximoPasso" class="form-control"
                               placeholder="Ex: Continuar a partir das integrais duplas" />
                    </div>

                    <div class="mb-0">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-question-circle me-1 text-warning"></i>Dúvidas (uma por linha)
                        </label>
                        <textarea name="duvidas" class="form-control" rows="3"
                                  placeholder="- O que é divergência de campo?&#10;- Diferença entre gradiente e jacobiano"></textarea>
                        <div class="form-text">Serão salvas automaticamente nas dúvidas da matéria ou artigo vinculado.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i>Salvar e Finalizar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ===== MODAL FINALIZAR =====
function abrirFinalizar(id) {
    document.getElementById('finalizarId').value = id;
    setStatus('Concluido', document.querySelector('.btn-status[data-status="Concluido"]'));
    var modal = new bootstrap.Modal(document.getElementById('modalFinalizar'));
    modal.show();
}

function setStatus(status, btn) {
    document.getElementById('finalizarStatus').value = status;
    document.querySelectorAll('.btn-status').forEach(b => {
        b.className = b.className.replace(/\bbtn-(success|warning|danger|info|dark)\b/, 'btn-outline-$1');
        b.classList.remove('active');
    });
    btn.className = btn.className.replace('btn-outline-', 'btn-');
    btn.classList.add('active');
}

// ===== TIMER =====
(function() {
    var timerEl = document.getElementById('timer-display');
    if (!timerEl) return;

    var horaFimStr = '@(Model.BlocoAtual?.HoraFim ?? "")';
    if (!horaFimStr) return;

    var parts = horaFimStr.split(':');
    var hoje = new Date();
    var fim = new Date(hoje.getFullYear(), hoje.getMonth(), hoje.getDate(),
                       parseInt(parts[0]), parseInt(parts[1]), 0);

    var notif5min = false;
    var notifFim = false;

    function tick() {
        var agora = new Date();
        var diff = Math.floor((fim - agora) / 1000);

        if (diff < 0) {
            timerEl.textContent = 'ENCERRADO';
            timerEl.classList.add('text-danger');
            if (!notifFim) {
                notifFim = true;
                tocarAlarme(880, 0.8, 1.0);
                notificar('Bloco encerrado', 'O tempo do bloco atual acabou.');
            }
            return;
        }

        var h = Math.floor(diff / 3600);
        var m = Math.floor((diff % 3600) / 60);
        var s = diff % 60;

        var texto = (h > 0 ? h + ':' : '') +
                    String(m).padStart(2, '0') + ':' +
                    String(s).padStart(2, '0');
        timerEl.textContent = texto;

        if (diff <= 300 && !notif5min) {
            notif5min = true;
            tocarAlarme(660, 0.4, 0.6);
            notificar('5 minutos restantes', '@(Model.BlocoAtual?.Titulo ?? "")');
        }
    }

    tick();
    setInterval(tick, 1000);
})();

// ===== WEB AUDIO =====
function tocarAlarme(freq, vol, duracao) {
    try {
        var ctx = new (window.AudioContext || window.webkitAudioContext)();
        var osc = ctx.createOscillator();
        var gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.frequency.value = freq;
        osc.type = 'sine';
        gain.gain.setValueAtTime(vol, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + duracao);
        osc.start(ctx.currentTime);
        osc.stop(ctx.currentTime + duracao);
    } catch(e) {}
}

// ===== NOTIFICAÇÕES =====
function notificar(titulo, corpo) {
    if (!('Notification' in window)) return;
    if (Notification.permission === 'granted') {
        new Notification(titulo, { body: corpo, icon: '/favicon.ico' });
    } else if (Notification.permission !== 'denied') {
        Notification.requestPermission().then(function(p) {
            if (p === 'granted') new Notification(titulo, { body: corpo });
        });
    }
}

// Solicita permissão ao carregar
if ('Notification' in window && Notification.permission === 'default') {
    Notification.requestPermission();
}
</script>
}
