@page
@model CadernoVivo.Pages.Hoje.IndexModel
@using CadernoVivo.Helpers
@using CadernoVivo.Models
@using System.Text.Json
@{
    ViewData["Title"] = "Hoje";
    var hoje = DateTime.Today;
    var diaSemana = DiasHelper.NomeDia((int)hoje.DayOfWeek);
    var dataFormatada = $"{diaSemana}, {hoje:dd/MM/yyyy}";
    var alertasHoje = Model.FilaBlocos.Select(b => new
    {
        id = b.Id,
        titulo = b.Titulo,
        data = b.Data.ToString("yyyy-MM-dd"),
        inicio = b.HoraInicio,
        fim = b.HoraFim,
        status = b.Status.ToString()
    });
}

@section Breadcrumb {
    <li class="breadcrumb-item active">Hoje</li>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-calendar-check me-2 text-primary"></i>@dataFormatada
    </h4>
    <div class="d-flex gap-2">
        <a asp-page="/PlanoImportar/Index" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-calendar-plus me-1"></i>Cronograma
        </a>
        <a asp-page="/Exportar/Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-box-arrow-up me-1"></i>Exportar
        </a>
    </div>
</div>

<div class="study-board">
    @if (!Model.FilaBlocos.Any())
    {
        <div class="card border-0 shadow-sm text-center py-5">
            <div class="card-body">
                <i class="bi bi-calendar-x display-3 text-muted"></i>
                <h5 class="mt-3 text-muted">Nenhum bloco planejado</h5>
                <p class="text-muted small">Importe um plano ou adicione um bloco manualmente.</p>
                <div class="d-flex gap-2 justify-content-center mt-3">
                    <a asp-page="/PlanoImportar/Index" class="btn btn-primary">
                        <i class="bi bi-calendar-plus me-1"></i>Abrir cronograma
                    </a>
                    <button class="btn btn-outline-secondary" type="button"
                            data-bs-toggle="collapse" data-bs-target="#formAdicionarBloco">
                        <i class="bi bi-plus-circle me-1"></i>Adicionar Bloco
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        var foco = Model.BlocoAtual
            ?? Model.FilaBlocos.FirstOrDefault(b => b.Status == StatusBloco.Pausado)
            ?? Model.FilaBlocos.FirstOrDefault(b => b.Status == StatusBloco.Agendado)
            ?? Model.FilaBlocos.First();
        var focoStatus = DiasHelper.ClasseStatusBloco(foco.Status);
        var progressoFila = Model.FilaBlocos.Count > 0
            ? (int)Math.Round((double)Model.BlocosConcluidosFila / Model.FilaBlocos.Count * 100)
            : 0;
        var focoTemHoraExtra = foco.MinutosExtras > 0;
        var focoTemCronometroAtivo = foco.Status == StatusBloco.EmAndamento || foco.Status == StatusBloco.Pausado;
        var textoInicialCronometro = foco.Status == StatusBloco.EmAndamento
            ? "--:--"
            : foco.Status == StatusBloco.Pausado
                ? "Pausado"
                : "Aguardando";

        <div class="focus-shell mb-3">
            <div class="focus-main">
                <div class="focus-kicker">
                    <span>@(Model.MostrandoProximaFila ? "Próxima fila" : "Fila de hoje")</span>
                    <span>@Model.DataFila.ToString("dd/MM/yyyy")</span>
                </div>
                <h3>@foco.Titulo</h3>
                @if (!string.IsNullOrWhiteSpace(foco.Descricao))
                {
                    <p>@foco.Descricao</p>
                }
                <div class="focus-tags">
                    <span class="badge bg-@focoStatus">@DiasHelper.LabelStatusBloco(foco.Status)</span>
                    @if (focoTemHoraExtra)
                    {
                        <span class="badge bg-dark">Hora extra +@foco.MinutosExtras min</span>
                    }
                    @if (foco.Materia != null)
                    {
                        <span class="badge bg-primary-subtle text-primary-emphasis">@foco.Materia.Nome</span>
                    }
                    @if (foco.Projeto != null)
                    {
                        <a asp-page="/Projetos/Detalhes" asp-route-id="@foco.ProjetoId"
                           class="badge bg-secondary-subtle text-secondary-emphasis text-decoration-none">
                            <i class="bi bi-kanban me-1"></i>@foco.Projeto.Titulo
                        </a>
                    }
                </div>
                <div class="focus-actions">
                    @if (foco.Status == StatusBloco.Pausado)
                    {
                        <form method="post" asp-page-handler="Retomar">
                            <input type="hidden" name="id" value="@foco.Id" />
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-play-fill"></i>Retomar
                            </button>
                        </form>
                    }
                    else if (foco.Status != StatusBloco.EmAndamento)
                    {
                        <form method="post" asp-page-handler="Iniciar">
                            <input type="hidden" name="id" value="@foco.Id" />
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-play-fill"></i>Iniciar agora
                            </button>
                        </form>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="Pausar">
                            <input type="hidden" name="id" value="@foco.Id" />
                            <button type="submit" class="btn btn-outline-warning">
                                <i class="bi bi-pause-fill"></i>Pausar tempo
                            </button>
                        </form>
                    }
                    @if (foco.Status == StatusBloco.EmAndamento || foco.Status == StatusBloco.Pausado)
                    {
                        <button class="btn btn-success" type="button" onclick="abrirFinalizar(@foco.Id)">
                            <i class="bi bi-check2-circle"></i>Finalizar bloco
                        </button>
                    }
                    <button class="btn btn-outline-secondary" type="button"
                            data-bs-toggle="collapse" data-bs-target="#formAdicionarBloco">
                        <i class="bi bi-plus-circle"></i>Adicionar
                    </button>
                    <button class="btn btn-outline-primary" type="button" id="btnAtivarAlertas">
                        <i class="bi bi-bell"></i>Ativar alertas
                    </button>
                </div>
                @if (foco.Status == StatusBloco.EmAndamento || foco.Status == StatusBloco.Pausado)
                {
                    <div class="d-flex gap-2 flex-wrap mt-3">
                        <form method="post" asp-page-handler="AdicionarTempo">
                            <input type="hidden" name="id" value="@foco.Id" />
                            <input type="hidden" name="minutos" value="10" />
                            <button type="submit" class="btn btn-sm btn-outline-dark">
                                <i class="bi bi-plus-lg"></i>+10 min extra
                            </button>
                        </form>
                        <form method="post" asp-page-handler="AdicionarTempo">
                            <input type="hidden" name="id" value="@foco.Id" />
                            <input type="hidden" name="minutos" value="15" />
                            <button type="submit" class="btn btn-sm btn-outline-dark">
                                <i class="bi bi-plus-lg"></i>+15 min extra
                            </button>
                        </form>
                        <form method="post" asp-page-handler="AdicionarTempo">
                            <input type="hidden" name="id" value="@foco.Id" />
                            <input type="hidden" name="minutos" value="30" />
                            <button type="submit" class="btn btn-sm btn-outline-dark">
                                <i class="bi bi-plus-lg"></i>+30 min extra
                            </button>
                        </form>
                    </div>
                }
            </div>
            <div class="focus-timer">
                <span class="timer-label">Cronômetro</span>
                <div data-live-timer
                     data-status="@foco.Status"
                     data-hora-inicio="@foco.HoraInicio"
                     data-hora-fim="@foco.HoraFim"
                     data-pausado-em="@(foco.PausadoEm?.ToString("o") ?? "")">
                    @textoInicialCronometro
                </div>
                <div class="timer-window">
                    @foco.HoraInicio - @foco.HoraFim
                    @if (focoTemHoraExtra)
                    {
                        <span> · hora extra +@foco.MinutosExtras min</span>
                    }
                </div>
                <div class="progress mt-3" style="height:6px">
                    <div class="progress-bar" style="width:@progressoFila%"></div>
                </div>
                <small class="text-muted">@Model.BlocosConcluidosFila/@Model.FilaBlocos.Count bloco(s) concluído(s)</small>
            </div>
        </div>

        @if (focoTemCronometroAtivo)
        {
            <aside class="floating-timer @(foco.Status == StatusBloco.Pausado ? "is-paused" : "is-running")"
                   data-floating-timer-shell>
                <div class="floating-timer-head">
                    <div class="d-flex align-items-start gap-2">
                        <span class="floating-timer-pulse" aria-hidden="true"></span>
                        <div>
                            <span class="floating-timer-kicker">
                                @(foco.Status == StatusBloco.Pausado ? "Bloco pausado" : "Bloco rolando")
                            </span>
                            <strong>@foco.Titulo</strong>
                        </div>
                    </div>
                    <span class="badge bg-@focoStatus">@DiasHelper.LabelStatusBloco(foco.Status)</span>
                </div>

                <div class="floating-timer-display"
                     data-live-timer
                     data-status="@foco.Status"
                     data-hora-inicio="@foco.HoraInicio"
                     data-hora-fim="@foco.HoraFim"
                     data-pausado-em="@(foco.PausadoEm?.ToString("o") ?? "")">
                    @textoInicialCronometro
                </div>

                <div class="floating-timer-meta">
                    <span>@foco.HoraInicio - @foco.HoraFim</span>
                    @if (focoTemHoraExtra)
                    {
                        <span>· extra +@foco.MinutosExtras min</span>
                    }
                </div>

                <div class="floating-timer-actions">
                    @if (foco.Status == StatusBloco.Pausado)
                    {
                        <form method="post" asp-page-handler="Retomar">
                            <input type="hidden" name="id" value="@foco.Id" />
                            <button type="submit" class="btn btn-warning btn-sm">
                                <i class="bi bi-play-fill"></i>Retomar
                            </button>
                        </form>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="Pausar">
                            <input type="hidden" name="id" value="@foco.Id" />
                            <button type="submit" class="btn btn-outline-warning btn-sm">
                                <i class="bi bi-pause-fill"></i>Pausar
                            </button>
                        </form>
                    }

                    <button class="btn btn-success btn-sm" type="button" onclick="abrirFinalizar(@foco.Id)">
                        <i class="bi bi-check2-circle"></i>Finalizar
                    </button>
                </div>
            </aside>
        }

        @if (Model.MostrandoProximaFila && Model.InicioSemanaProximaData.HasValue)
        {
            <div class="alert alert-info d-flex justify-content-between align-items-center gap-2 flex-wrap">
                <span>
                    Hoje está vazio. Mostrando a próxima fila planejada para
                    <strong>@Model.ProximaDataComBlocos?.ToString("dd/MM/yyyy")</strong>.
                </span>
                <a asp-page="/Faculdade/PlanoDaSemana/Index"
                   asp-route-inicio="@Model.InicioSemanaProximaData.Value.ToString("yyyy-MM-dd")"
                   class="btn btn-sm btn-outline-primary">
                    Abrir Plano da Semana
                </a>
            </div>
        }

        <div class="lesson-queue">
            @for (var i = 0; i < Model.FilaBlocos.Count; i++)
            {
                var b = Model.FilaBlocos[i];
                var isAtual = Model.BlocoAtual?.Id == b.Id;
                var itemClass = isAtual ? "queue-item active" : "queue-item";
                var blocoTemHoraExtra = b.MinutosExtras > 0;
                <div class="@itemClass" id="bloco-@b.Id">
                    <div class="queue-index">@(i + 1)</div>
                    <div class="queue-time">
                        <span>@b.HoraInicio</span>
                        <small>@b.HoraFim</small>
                    </div>
                    <div class="queue-body">
                        <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                            <div>
                                <div class="queue-title">@b.Titulo</div>
                                @if (!string.IsNullOrWhiteSpace(b.Descricao))
                                {
                                    <div class="queue-desc">@b.Descricao</div>
                                }
                                @if (!string.IsNullOrWhiteSpace(b.Duvidas))
                                {
                                    <div class="small text-muted mt-1"><i class="bi bi-sticky me-1"></i>@b.Duvidas</div>
                                }
                            </div>
                            <span class="badge bg-@DiasHelper.ClasseStatusBloco(b.Status)">
                                @DiasHelper.LabelStatusBloco(b.Status)
                            </span>
                        </div>
                        <div class="queue-meta">
                            @if (b.Materia != null)
                            {
                                <span><i class="bi bi-mortarboard"></i>@b.Materia.Nome</span>
                            }
                            @if (b.Projeto != null)
                            {
                                <a asp-page="/Projetos/Detalhes" asp-route-id="@b.ProjetoId"
                                   class="text-decoration-none text-secondary">
                                    <i class="bi bi-kanban"></i>@b.Projeto.Titulo
                                </a>
                            }
                            @if (!string.IsNullOrWhiteSpace(b.OndeParei))
                            {
                                <span><i class="bi bi-bookmark"></i>@b.OndeParei</span>
                            }
                            @if (blocoTemHoraExtra)
                            {
                                <span><i class="bi bi-clock-history"></i>Hora extra +@b.MinutosExtras min</span>
                            }
                        </div>
                        <div class="queue-actions">
                            @if (b.Status == StatusBloco.Pausado)
                            {
                                <form method="post" asp-page-handler="Retomar">
                                    <input type="hidden" name="id" value="@b.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-play-fill"></i>Retomar
                                    </button>
                                </form>
                            }
                            else if (b.Status != StatusBloco.EmAndamento)
                            {
                                <form method="post" asp-page-handler="Iniciar">
                                    <input type="hidden" name="id" value="@b.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-play-fill"></i>Iniciar
                                    </button>
                                </form>
                            }
                            @if (b.Status == StatusBloco.EmAndamento)
                            {
                                <form method="post" asp-page-handler="Pausar">
                                    <input type="hidden" name="id" value="@b.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-pause-fill"></i>Pausar
                                    </button>
                                </form>
                            }
                            @if (b.Status == StatusBloco.Agendado || b.Status == StatusBloco.EmAndamento || b.Status == StatusBloco.Pausado)
                            {
                                <button class="btn btn-sm btn-outline-success" type="button" onclick="abrirFinalizar(@b.Id)">
                                    <i class="bi bi-check2"></i>Finalizar
                                </button>
                            }
                            @if (b.Status == StatusBloco.EmAndamento || b.Status == StatusBloco.Pausado)
                            {
                                <form method="post" asp-page-handler="AdicionarTempo">
                                    <input type="hidden" name="id" value="@b.Id" />
                                    <input type="hidden" name="minutos" value="15" />
                                    <button type="submit" class="btn btn-sm btn-outline-dark">
                                        <i class="bi bi-plus-lg"></i>+15
                                    </button>
                                </form>
                            }
                            <button class="btn btn-sm btn-outline-secondary" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#ajustar-fila-@b.Id">
                                <i class="bi bi-sliders"></i>Ajustar
                            </button>
                            <form method="post" asp-page-handler="Excluir" class="d-inline"
                                  onsubmit="return confirm('Excluir este bloco?')">
                                <input type="hidden" name="id" value="@b.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                        <div class="collapse mt-2" id="ajustar-fila-@b.Id">
                            <form method="post" asp-page-handler="AjustarBloco" class="quick-adjust">
                                <input type="hidden" name="id" value="@b.Id" />
                                <div class="row g-2">
                                    <div class="col-md-3">
                                        <label class="form-label small fw-semibold">Data</label>
                                        <input type="text" name="data" class="form-control form-control-sm"
                                               value="@b.Data.ToString("dd/MM/yyyy")"
                                               placeholder="dd/mm/aaaa" inputmode="numeric" data-br-date />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small fw-semibold">Início</label>
                                        <input type="text" name="horaInicio" class="form-control form-control-sm"
                                               value="@b.HoraInicio" placeholder="19:30" inputmode="numeric" data-br-time />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small fw-semibold">Fim</label>
                                        <input type="text" name="horaFim" class="form-control form-control-sm"
                                               value="@b.HoraFim" placeholder="21:00" inputmode="numeric" data-br-time />
                                    </div>
                                    <div class="col-md-5">
                                        <label class="form-label small fw-semibold">Título</label>
                                        <input type="text" name="titulo" class="form-control form-control-sm"
                                               value="@b.Titulo" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label small fw-semibold">Descrição</label>
                                        <input type="text" name="descricao" class="form-control form-control-sm"
                                               value="@b.Descricao" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label small fw-semibold">Observações</label>
                                        <textarea name="observacoes" class="form-control form-control-sm" rows="2"
                                                  placeholder="Notas, dúvidas ou pontos para não esquecer...">@b.Duvidas</textarea>
                                    </div>
                                    <div class="col-12 text-end">
                                        <button type="submit" class="btn btn-sm btn-primary">
                                            <i class="bi bi-save me-1"></i>Salvar ajuste
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (focoTemCronometroAtivo)
        {
            <div class="floating-timer-spacer" aria-hidden="true"></div>
        }
    }
</div>

<div class="cv-toast" id="cvToast" hidden>
    <div class="cv-toast-icon"><i class="bi bi-bell-fill"></i></div>
    <div class="cv-toast-body">
        <strong id="cvToastTitle">Alerta</strong>
        <span id="cvToastBody">Seu bloco vai começar.</span>
    </div>
    <button type="button" class="cv-toast-dismiss" id="cvToastDismiss" title="Desligar alarme">
        <i class="bi bi-bell-slash-fill"></i>
        <span>Desligar</span>
    </button>
</div>

<!-- Form Adicionar Bloco (sempre presente) -->
<div class="collapse mt-3" id="formAdicionarBloco">
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent border-0">
            <h6 class="fw-bold mb-0"><i class="bi bi-plus-circle me-2"></i>Adicionar bloco rápido</h6>
        </div>
        <div class="card-body">
            <form method="post" asp-page-handler="AdicionarBloco">
                <div class="row g-2">
                    <div class="col-md-2">
                        <label class="form-label small fw-semibold">Data</label>
                        <input asp-for="NovoBloco.Data" type="text" class="form-control form-control-sm"
                               value="@DateTime.Today.ToString("dd/MM/yyyy")"
                               placeholder="dd/mm/aaaa" inputmode="numeric" data-br-date />
                    </div>
                    <div class="col-md-1">
                        <label class="form-label small fw-semibold">Início</label>
                        <input asp-for="NovoBloco.HoraInicio" type="text" class="form-control form-control-sm"
                               placeholder="19:30" inputmode="numeric" data-br-time />
                    </div>
                    <div class="col-md-1">
                        <label class="form-label small fw-semibold">Fim</label>
                        <input asp-for="NovoBloco.HoraFim" type="text" class="form-control form-control-sm"
                               placeholder="21:00" inputmode="numeric" data-br-time />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Título *</label>
                        <input asp-for="NovoBloco.Titulo" class="form-control form-control-sm" placeholder="Ex: Cálculo – Derivadas" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-semibold">Módulo</label>
                        <select asp-for="NovoBloco.Modulo" class="form-select form-select-sm">
                            <option value="Geral">Geral</option>
                            <option value="Faculdade">Faculdade</option>
                            <option value="Projeto">Projeto</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-semibold">Matéria</label>
                        <select asp-for="NovoBloco.MateriaId" class="form-select form-select-sm">
                            <option value="">— nenhuma —</option>
                            @foreach (var m in Model.Materias)
                            {
                                <option value="@m.Id">@m.Nome</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-semibold">Projeto</label>
                        <select asp-for="NovoBloco.ProjetoId" class="form-select form-select-sm">
                            <option value="">— nenhum —</option>
                            @foreach (var pr in Model.Projetos)
                            {
                                <option value="@pr.Id">@pr.Titulo</option>
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-semibold">Descrição / Objetivo</label>
                        <input asp-for="NovoBloco.Descricao" class="form-control form-control-sm"
                               placeholder="Opcional — o que será feito neste bloco" />
                    </div>
                    <div class="col-12 text-end">
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="bi bi-plus-circle me-1"></i>Adicionar Bloco
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Finalizar Bloco -->
<div class="modal fade" id="modalFinalizar" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-check2-circle me-2"></i>Finalizar Bloco</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Finalizar" id="formFinalizar">
                <div class="modal-body">
                    <input type="hidden" name="id" id="finalizarId" />

                    <!-- Botões de status -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Como foi este bloco?</label>
                        <input type="hidden" name="status" id="finalizarStatus" value="Concluido" />
                        <div class="d-flex gap-2 flex-wrap">
                            <button type="button" class="btn btn-success btn-status active"
                                    data-status="Concluido" onclick="setStatus('Concluido', this)">
                                <i class="bi bi-check-circle-fill me-1"></i>Concluído
                            </button>
                            <button type="button" class="btn btn-outline-warning btn-status"
                                    data-status="Parcial" onclick="setStatus('Parcial', this)">
                                <i class="bi bi-dash-circle me-1"></i>Parcial
                            </button>
                            <button type="button" class="btn btn-outline-danger btn-status"
                                    data-status="NaoFeito" onclick="setStatus('NaoFeito', this)">
                                <i class="bi bi-x-circle me-1"></i>Não Feito
                            </button>
                            <button type="button" class="btn btn-outline-info btn-status"
                                    data-status="Reagendado" onclick="setStatus('Reagendado', this)">
                                <i class="bi bi-calendar-plus me-1"></i>Reagendar
                            </button>
                            <button type="button" class="btn btn-outline-dark btn-status"
                                    data-status="HoraExtra" onclick="setStatus('HoraExtra', this)">
                                <i class="bi bi-clock-history me-1"></i>Hora Extra
                            </button>
                        </div>
                        <div class="form-text mt-2">Os minutos adicionados em "tempo extra" ja entram nas métricas de hora extra, mesmo se você finalizar como concluído.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-bookmark me-1 text-primary"></i>Onde parei
                        </label>
                        <input type="text" name="ondeParei" class="form-control"
                               placeholder="Ex: Página 47, seção 3.2 — Derivadas parciais" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-arrow-right-circle me-1 text-success"></i>Próximo passo
                        </label>
                        <input type="text" name="proximoPasso" class="form-control"
                               placeholder="Ex: Continuar a partir das integrais duplas" />
                    </div>

                    <div class="mb-0">
                        <label class="form-label fw-semibold">
                            <i class="bi bi-sticky me-1 text-warning"></i>Observações / dúvidas do bloco
                        </label>
                        <textarea name="duvidas" class="form-control" rows="3"
                                  placeholder="- dúvida que apareceu&#10;- ponto importante para revisar&#10;- detalhe que eu não posso esquecer"></textarea>
                        <div class="form-text">Fica anexado ao dia/bloco estudado e aparece no dashboard em Observações recentes.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i>Salvar e Finalizar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
const blocosAlertas = @Html.Raw(JsonSerializer.Serialize(alertasHoje));

// ===== MODAL FINALIZAR =====
function abrirFinalizar(id) {
    document.getElementById('finalizarId').value = id;
    setStatus('Concluido', document.querySelector('.btn-status[data-status="Concluido"]'));
    var modal = new bootstrap.Modal(document.getElementById('modalFinalizar'));
    modal.show();
}

function setStatus(status, btn) {
    document.getElementById('finalizarStatus').value = status;
    document.querySelectorAll('.btn-status').forEach(b => {
        b.className = b.className.replace(/\bbtn-(success|warning|danger|info|dark)\b/, 'btn-outline-$1');
        b.classList.remove('active');
    });
    btn.className = btn.className.replace('btn-outline-', 'btn-');
    btn.classList.add('active');
}

// ===== TIMER =====
(function() {
    var timerEls = Array.from(document.querySelectorAll('[data-live-timer]'));
    if (!timerEls.length) return;

    var baseTimerEl = timerEls[0];
    var status = baseTimerEl.dataset.status || '';
    var horaInicioStr = baseTimerEl.dataset.horaInicio || '';
    var horaFimStr = baseTimerEl.dataset.horaFim || '';
    var pausadoEmStr = baseTimerEl.dataset.pausadoEm || '';
    if (!horaFimStr || (status !== 'EmAndamento' && status !== 'Pausado')) return;

    function atualizarTemporizadores(texto, emPerigo) {
        timerEls.forEach(function(timerEl) {
            timerEl.textContent = texto;
            timerEl.classList.toggle('text-danger', !!emPerigo);
        });
    }

    function atualizarEstadoFlutuante(estado) {
        document.querySelectorAll('[data-floating-timer-shell]').forEach(function(shell) {
            shell.classList.remove('is-running', 'is-paused', 'is-finished');
            if (estado) shell.classList.add(estado);
        });
    }

    function montarHorario(hora, base, horaInicio) {
        var parts = hora.split(':').map(Number);
        var data = new Date(base.getFullYear(), base.getMonth(), base.getDate(),
            parts[0], parts[1], 0);

        if (horaInicio) {
            var inicioParts = horaInicio.split(':').map(Number);
            var cruzouMeiaNoite =
                parts[0] < inicioParts[0] ||
                (parts[0] === inicioParts[0] && parts[1] <= inicioParts[1]);

            if (cruzouMeiaNoite) data.setDate(data.getDate() + 1);
        }

        return data;
    }

    function formatar(diff) {
        var total = Math.max(0, diff);
        var h = Math.floor(total / 3600);
        var m = Math.floor((total % 3600) / 60);
        var s = total % 60;
        return (h > 0 ? h + ':' : '') +
            String(m).padStart(2, '0') + ':' +
            String(s).padStart(2, '0');
    }

    var hoje = new Date();
    var fim = montarHorario(horaFimStr, hoje, horaInicioStr);

    var notif5min = false;
    var notifFim = false;

    if (status === 'Pausado' && pausadoEmStr) {
        var pausadoEm = new Date(pausadoEmStr);
        var diffPausado = Math.floor((fim - pausadoEm) / 1000);
        atualizarTemporizadores('Pausado · ' + formatar(diffPausado), false);
        atualizarEstadoFlutuante('is-paused');
        return;
    }

    function tick() {
        var agora = new Date();
        var diff = Math.floor((fim - agora) / 1000);

        if (diff < 0) {
            atualizarTemporizadores('ENCERRADO', true);
            atualizarEstadoFlutuante('is-finished');
            if (!notifFim) {
                notifFim = true;
                notificar('Bloco encerrado', 'O tempo do bloco atual acabou.');
            }
            return;
        }

        atualizarTemporizadores(formatar(diff), false);
        atualizarEstadoFlutuante('is-running');

        if (diff <= 300 && !notif5min) {
            notif5min = true;
            notificar('5 minutos restantes', '@(Model.BlocoAtual?.Titulo ?? "")');
        }
    }

    tick();
    setInterval(tick, 1000);
})();

// ===== WEB AUDIO =====
var _audioCtx = null;
function getAudioCtx() {
    try {
        if (!_audioCtx || _audioCtx.state === 'closed') {
            _audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        }
        if (_audioCtx.state === 'suspended') _audioCtx.resume();
        return _audioCtx;
    } catch(e) { return null; }
}

function tocarTom(freq, vol, duracao, delay) {
    try {
        var ctx = getAudioCtx();
        if (!ctx) return;
        var osc = ctx.createOscillator();
        var gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.frequency.value = freq;
        osc.type = 'sine';
        var t = ctx.currentTime + (delay || 0);
        gain.gain.setValueAtTime(0.001, t);
        gain.gain.linearRampToValueAtTime(vol, t + 0.01);
        gain.gain.exponentialRampToValueAtTime(0.001, t + duracao);
        osc.start(t);
        osc.stop(t + duracao + 0.05);
    } catch(e) {}
}

function tocarSequenciaAlerta() {
    // 3 bipes rápidos + tom longo urgente
    tocarTom(880, 0.5, 0.12, 0.00);
    tocarTom(880, 0.5, 0.12, 0.16);
    tocarTom(880, 0.5, 0.12, 0.32);
    tocarTom(1320, 0.55, 0.40, 0.55);
}

// ===== TOAST =====
var _toastTimer = null;

function mostrarToast(titulo, corpo) {
    var toast = document.getElementById('cvToast');
    if (!toast) return;
    document.getElementById('cvToastTitle').textContent = titulo;
    document.getElementById('cvToastBody').textContent = corpo;
    toast.classList.remove('alarme-ativo');
    document.getElementById('cvToastDismiss').hidden = true;
    toast.hidden = false;
    toast.classList.add('show');
    clearTimeout(_toastTimer);
    _toastTimer = setTimeout(function() {
        toast.classList.remove('show');
        setTimeout(function() { toast.hidden = true; }, 200);
    }, 7000);
}

// ===== ALARME PERSISTENTE =====
var _alarmeInterval = null;
var _alarmeTicks = 0;
var ALARME_MAX_TICKS = 10; // 10 × 3s = 30 segundos

function pararAlarme() {
    if (_alarmeInterval) { clearInterval(_alarmeInterval); _alarmeInterval = null; }
    var toast = document.getElementById('cvToast');
    if (!toast) return;
    toast.classList.remove('show', 'alarme-ativo');
    setTimeout(function() { toast.hidden = true; }, 200);
}

function dispararAlarme(titulo, corpo) {
    if (_alarmeInterval) clearInterval(_alarmeInterval);
    _alarmeTicks = 0;

    var toast = document.getElementById('cvToast');
    if (toast) {
        document.getElementById('cvToastTitle').textContent = titulo;
        document.getElementById('cvToastBody').textContent = corpo;
        document.getElementById('cvToastDismiss').hidden = false;
        toast.hidden = false;
        toast.classList.add('show', 'alarme-ativo');
    }

    tocarSequenciaAlerta();

    _alarmeInterval = setInterval(function() {
        _alarmeTicks++;
        if (_alarmeTicks >= ALARME_MAX_TICKS) { pararAlarme(); return; }
        tocarSequenciaAlerta();
    }, 3000);
}

document.getElementById('cvToastDismiss')?.addEventListener('click', pararAlarme);

// ===== NOTIFICAÇÕES =====
var ALERTAS_KEY = 'cv:alertasAtivos';
var _alertaTimeouts = [];

function alertasAtivos() {
    // Padrao ligado: se o usuario nunca mexeu, o app ja agenda quando a tela Hoje abre.
    return localStorage.getItem(ALERTAS_KEY) !== '0';
}

function atualizarBotaoAlertas() {
    var btn = document.getElementById('btnAtivarAlertas');
    if (!btn) return;

    if (alertasAtivos()) {
        btn.classList.remove('btn-outline-primary');
        btn.classList.add('btn-success');
        btn.innerHTML = '<i class="bi bi-bell-fill"></i>Alertas ligados';
    } else {
        btn.classList.remove('btn-success');
        btn.classList.add('btn-outline-primary');
        btn.innerHTML = '<i class="bi bi-bell-slash"></i>Alertas desligados';
    }
}

function limparAgendamentosDeAlerta() {
    _alertaTimeouts.forEach(clearTimeout);
    _alertaTimeouts = [];
}

function notificar(titulo, corpo) {
    dispararAlarme(titulo, corpo);
    if (!('Notification' in window)) return;
    if (Notification.permission === 'granted') {
        new Notification(titulo, { body: corpo, icon: '/favicon.ico' });
    } else if (Notification.permission !== 'denied') {
        Notification.requestPermission().then(function(p) {
            if (p === 'granted') new Notification(titulo, { body: corpo });
        });
    }
}

function dataHoraBloco(bloco) {
    var partesData = bloco.data.split('-').map(Number);
    var partesHora = bloco.inicio.split(':').map(Number);
    return new Date(partesData[0], partesData[1] - 1, partesData[2], partesHora[0], partesHora[1], 0);
}

function agendarAlertasDoDia() {
    limparAgendamentosDeAlerta();
    if (!alertasAtivos()) return;

    var hoje = new Date();
    var hojeKey = hoje.getFullYear() + '-' +
        String(hoje.getMonth() + 1).padStart(2, '0') + '-' +
        String(hoje.getDate()).padStart(2, '0');

    blocosAlertas
        .filter(function(bloco) {
            return bloco.data === hojeKey && bloco.status !== 'Concluido' && bloco.status !== 'NaoFeito';
        })
        .forEach(function(bloco) {
            var inicio = dataHoraBloco(bloco);
            var alerta = new Date(inicio.getTime() - 10 * 60 * 1000);
            var delay = alerta.getTime() - Date.now();
            var titulo = 'Daqui 10 minutos';
            var corpo = bloco.titulo + ' começa às ' + bloco.inicio + '.';

            if (delay > 0) {
                _alertaTimeouts.push(setTimeout(function() { notificar(titulo, corpo); }, delay));
            } else if (inicio.getTime() > Date.now() && inicio.getTime() - Date.now() <= 10 * 60 * 1000) {
                notificar(titulo, corpo);
            }
        });
}

function ativarAlertas() {
    localStorage.setItem(ALERTAS_KEY, '1');
    atualizarBotaoAlertas();

    if ('Notification' in window && Notification.permission === 'default') {
        Notification.requestPermission().then(function() {
            tocarSequenciaAlerta();
            mostrarToast('Alertas ativados', 'Vou avisar 10 minutos antes dos blocos de hoje.');
            agendarAlertasDoDia();
        });
        return;
    }

    tocarSequenciaAlerta();
    mostrarToast('Alertas ativados', 'Vou avisar 10 minutos antes dos blocos de hoje.');
    agendarAlertasDoDia();
}

function desativarAlertas() {
    localStorage.setItem(ALERTAS_KEY, '0');
    limparAgendamentosDeAlerta();
    atualizarBotaoAlertas();
    mostrarToast('Alertas desligados', 'Nao vou tocar avisos automaticamente nesta tela.');
}

function alternarAlertas() {
    if (alertasAtivos()) desativarAlertas();
    else ativarAlertas();
}

document.getElementById('btnAtivarAlertas')?.addEventListener('click', alternarAlertas);

// Ajuda o navegador a liberar audio assim que houver qualquer interacao com a pagina.
document.addEventListener('pointerdown', function() {
    getAudioCtx();
}, { once: true });

atualizarBotaoAlertas();
agendarAlertasDoDia();
</script>
}
