@page
@model CadernoVivo.Pages.Exportar.IndexModel
@using CadernoVivo.Helpers
@using CadernoVivo.Models
@{
    ViewData["Title"] = "Exportar";
}

@section Breadcrumb {
    <li class="breadcrumb-item active">Exportar</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-box-arrow-up me-2 text-primary"></i>Exportar Estado Atual</h4>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <i class="bi bi-file-earmark-text display-4 text-success mb-3"></i>
                <h5 class="fw-bold">Exportar Markdown</h5>
                <p class="text-muted small">Ideal para colar diretamente no ChatGPT. Formato legível com todas as informações estruturadas.</p>
                <a asp-page-handler="Markdown" class="btn btn-success">
                    <i class="bi bi-download me-2"></i>Baixar .md
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <i class="bi bi-filetype-json display-4 text-primary mb-3"></i>
                <h5 class="fw-bold">Exportar JSON</h5>
                <p class="text-muted small">Para importar de volta um plano atualizado. Formato estruturado compatível com o importador.</p>
                <a asp-page-handler="Json" class="btn btn-primary">
                    <i class="bi bi-download me-2"></i>Baixar .json
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center py-4">
                <i class="bi bi-calendar-event display-4 text-info mb-3"></i>
                <h5 class="fw-bold">Calendário com alarmes</h5>
                <p class="text-muted small">Arquivo .ics com todos os blocos e alerta 10 minutos antes. Pode importar no calendário do PC ou Google.</p>
                <a asp-page-handler="Calendario" class="btn btn-info text-white">
                    <i class="bi bi-download me-2"></i>Baixar .ics
                </a>
            </div>
        </div>
    </div>
</div>

<div class="alert alert-info small">
    <i class="bi bi-info-circle me-2"></i>
    Para apitar no celular sem o PC ligado, importe o arquivo <strong>.ics</strong> no Google Calendar ou em um calendário sincronizado com o telefone.
    Assinatura automática por URL só funciona se este app estiver publicado em um endereço acessível pelo Google, não apenas em <code>localhost</code>.
</div>

<!-- Preview do conteúdo -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent border-0">
        <h6 class="fw-bold mb-0"><i class="bi bi-eye me-2"></i>Preview do Export</h6>
    </div>
    <div class="card-body">

        <!-- Blocos de hoje -->
        <h6 class="fw-semibold text-muted text-uppercase small mb-2">Blocos de Hoje (@DateTime.Today:dd/MM/yyyy)</h6>
        @if (Model.BloquesHoje.Any())
        {
            <div class="table-responsive mb-3">
                <table class="table table-sm table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Horário</th>
                            <th>Bloco</th>
                            <th>Status</th>
                            <th>Onde parei</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.BloquesHoje)
                        {
                            <tr>
                                <td class="font-monospace small">@b.HoraInicio–@b.HoraFim</td>
                                <td>
                                    @b.Titulo
                                    @if (b.Materia != null) { <small class="text-muted ms-1">(@b.Materia.Nome)</small> }
                                    @if (b.Artigo != null) { <small class="text-muted ms-1">(@b.Artigo.Titulo)</small> }
                                </td>
                                <td><span class="badge bg-@DiasHelper.ClasseStatusBloco(b.Status)">@DiasHelper.LabelStatusBloco(b.Status)</span></td>
                                <td class="small text-muted">@(b.OndeParei ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted small mb-3"><em>Nenhum bloco hoje.</em></p>
        }

        <!-- Pendências -->
        <h6 class="fw-semibold text-muted text-uppercase small mb-2">Pendências Abertas (@Model.Pendencias.Count)</h6>
        @if (Model.Pendencias.Any())
        {
            <ul class="list-unstyled mb-3">
                @foreach (var p in Model.Pendencias.Take(5))
                {
                    <li class="mb-1 small">
                        <i class="bi bi-exclamation-circle text-warning me-1"></i>
                        <strong>[@p.Origem]</strong> @p.Descricao
                        @if (p.DataLimite.HasValue)
                        {
                            <span class="text-muted"> – até @p.DataLimite.Value:dd/MM</span>
                        }
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-muted small mb-3"><em>Nenhuma pendência aberta.</em></p>
        }

        <p class="text-muted small mb-0">
            Trabalhos e coisas avulsas agora ficam em <strong>Projetos</strong> e <strong>Lembretes</strong>.
        </p>
    </div>
</div>
